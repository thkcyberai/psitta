# ══════════════════════════════════════════════════════════════════════
# Psitta — Environment Variables
# Copy to .env and fill in secrets before running:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Database (PostgreSQL) ──────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=psitta
DATABASE_USER=psitta
DATABASE_PASSWORD=CHANGE-ME-psitta-dev-password
DATABASE_POOL_SIZE=10
DATABASE_POOL_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Object Storage (S3 / MinIO) ───────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=psitta-storage
AWS_ACCESS_KEY_ID=CHANGE-ME-minio-access-key
AWS_SECRET_ACCESS_KEY=CHANGE-ME-minio-secret-key

# ── Azure Cognitive Services (TTS) ────────────────────────────────────
# Sign up: https://azure.microsoft.com/en-us/products/ai-services/text-to-speech
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus

# ── Anthropic (Vision Descriptions) ───────────────────────────────────
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Security ───────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret

# ── Observability (optional) ───────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=psitta-api
# SENTRY_DSN=

# -- ElevenLabs TTS --
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
