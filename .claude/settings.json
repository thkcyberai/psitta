{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_stop_update_claude_md.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
