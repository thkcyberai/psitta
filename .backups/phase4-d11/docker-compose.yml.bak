# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Psitta — Docker Compose (Development)                           ║
# ║  Usage:  cp .env.example .env && docker compose up -d               ║
# ║  Prod:   docker compose -f docker-compose.yml -f compose.prod.yml   ║
# ╚══════════════════════════════════════════════════════════════════════╝

services:
  # ─── PostgreSQL 16 ───────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: psitta-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-psitta}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-psitta_dev}
      POSTGRES_DB: ${POSTGRES_DB:-psitta}
      POSTGRES_INITDB_ARGS: "--auth-host=scram-sha-256"
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - backend
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-psitta} -d ${POSTGRES_DB:-psitta}"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "1.0"
        reservations:
          memory: 256M
    security_opt:
      - no-new-privileges:true
    shm_size: 256mb

  # ─── Redis 7 (cache + job queue via Streams) ────────────────────────
  redis:
    image: redis:7-alpine
    container_name: psitta-redis
    restart: unless-stopped
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redisdata:/data
    networks:
      - backend
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 5s
    command: >-
      redis-server
        --appendonly yes
        --maxmemory 256mb
        --maxmemory-policy allkeys-lru
        --tcp-backlog 511
        --save 60 1000
        --loglevel warning
    deploy:
      resources:
        limits:
          memory: 384M
          cpus: "0.5"
        reservations:
          memory: 128M
    security_opt:
      - no-new-privileges:true
    read_only: true
    tmpfs:
      - /tmp:size=64M

  # ─── MinIO (S3-compatible object storage for dev) ───────────────────
  minio:
    image: minio/minio:RELEASE.2024-11-07T00-52-20Z
    container_name: psitta-minio
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: ${S3_ACCESS_KEY:-minioadmin}
      MINIO_ROOT_PASSWORD: ${S3_SECRET_KEY:-minioadmin}
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - miniodata:/data
    networks:
      - backend
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "0.5"

  # ─── MinIO bucket bootstrap ────────────────────────────────────────
  minio-init:
    image: minio/mc:RELEASE.2024-11-17T19-35-25Z
    container_name: psitta-minio-init
    depends_on:
      minio:
        condition: service_healthy
    networks:
      - backend
    restart: "no"
    entrypoint: >
      /bin/sh -c "
        mc alias set local http://minio:9000 $${MINIO_ROOT_USER:-minioadmin} $${MINIO_ROOT_PASSWORD:-minioadmin};
        mc mb --ignore-existing local/${S3_BUCKET_NAME:-psitta-dev};
        mc anonymous set download local/${S3_BUCKET_NAME:-psitta-dev}/voices;
        echo 'Bucket ready';
      "

  # ─── API Server ─────────────────────────────────────────────────────
  api:
    build:
      context: ./core/backend
      dockerfile: Dockerfile
      target: runtime
    container_name: psitta-api
    restart: unless-stopped
    env_file: .env
    environment:
      DATABASE_URL: "postgresql+asyncpg://${POSTGRES_USER:-psitta}:${POSTGRES_PASSWORD:-psitta_dev}@postgres:5432/${POSTGRES_DB:-psitta}"
      REDIS_URL: "redis://redis:6379/0"
      S3_ENDPOINT_URL: "http://minio:9000"
    ports:
      - "${API_PORT:-8000}:8000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
    networks:
      - backend
    volumes:
      - ./core/backend/src:/app/src:ro
    command: >
      uvicorn psitta.main:create_app --factory
      --host 0.0.0.0 --port 8000 --reload
      --log-level ${LOG_LEVEL:-debug}
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: "1.0"
        reservations:
          memory: 256M
    security_opt:
      - no-new-privileges:true
    tmpfs:
      - /tmp:size=256M

  # ─── Document Processing Worker ─────────────────────────────────────
  worker:
    build:
      context: ./core/backend
      dockerfile: Dockerfile
      target: runtime
    container_name: psitta-worker
    restart: unless-stopped
    env_file: .env
    environment:
      DATABASE_URL: "postgresql+asyncpg://${POSTGRES_USER:-psitta}:${POSTGRES_PASSWORD:-psitta_dev}@postgres:5432/${POSTGRES_DB:-psitta}"
      REDIS_URL: "redis://redis:6379/0"
      S3_ENDPOINT_URL: "http://minio:9000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
    networks:
      - backend
    volumes:
      - ./core/backend/src:/app/src:ro
    command: python -m psitta.workers.document_processor
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: "2.0"
        reservations:
          memory: 512M
    security_opt:
      - no-new-privileges:true
    tmpfs:
      - /tmp:size=512M

  # ─── Database migrations (run once) ─────────────────────────────────
  migrate:
    build:
      context: ./core/backend
      dockerfile: Dockerfile
      target: runtime
    container_name: psitta-migrate
    env_file: .env
    environment:
      DATABASE_URL: "postgresql+asyncpg://${POSTGRES_USER:-psitta}:${POSTGRES_PASSWORD:-psitta_dev}@postgres:5432/${POSTGRES_DB:-psitta}"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - backend
    command: alembic -c /app/src/psitta/db/alembic.ini upgrade head
    restart: "no"
    profiles:
      - migrate

networks:
  backend:
    driver: bridge
    name: psitta-net

volumes:
  pgdata:
    driver: local
  redisdata:
    driver: local
  miniodata:
    driver: local
