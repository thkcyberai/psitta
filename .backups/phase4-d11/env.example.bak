# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Psitta — Environment Configuration                              ║
# ║  Copy to .env and fill in secrets. NEVER commit .env to git.        ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Application ────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
APP_VERSION=0.1.0
LOG_LEVEL=debug                  # debug | info | warning | error
SECRET_KEY=CHANGE-ME-TO-RANDOM-64-CHAR-STRING

# ── API Server ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                    # Uvicorn workers (production: 2 * CPU + 1)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=psitta
POSTGRES_USER=psitta
POSTGRES_PASSWORD=CHANGE-ME-postgres-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=10
DATABASE_POOL_OVERFLOW=5

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
REDIS_CACHE_TTL=3600             # Default cache TTL in seconds

# ── S3 / Object Storage ───────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000      # MinIO for local dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE-ME-minio-secret
S3_BUCKET_NAME=psitta-dev
S3_REGION=us-east-1
S3_USE_SSL=false                       # true in production (AWS S3)

# ── Authentication (Auth0 / Clerk) ─────────────────────────────────────
AUTH_PROVIDER=auth0              # auth0 | clerk
AUTH_DOMAIN=your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_CLIENT_SECRET=CHANGE-ME-auth-client-secret
AUTH_AUDIENCE=https://api.psitta.io
AUTH_ISSUER=https://your-tenant.auth0.com/

# ── Azure Cognitive Services (TTS) ─────────────────────────────────────
AZURE_TTS_KEY=CHANGE-ME-azure-tts-key
AZURE_TTS_REGION=eastus
AZURE_TTS_ENDPOINT=https://${AZURE_TTS_REGION}.tts.speech.microsoft.com

# ── Anthropic (Vision Descriptions) ────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE-ME-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Observability ──────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=psitta-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1     # Sample 10% of traces in production
SENTRY_DSN=                      # Optional: Sentry error tracking

# ── Worker ─────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL=2           # Seconds between job polls
WORKER_MAX_CONCURRENT=3          # Max parallel document processing jobs
WORKER_MAX_RETRIES=3

# ── Feature Flags ──────────────────────────────────────────────────────
ENABLE_CUSTOM_VOICES=false       # v2 feature: voice cloning
ENABLE_PREMIUM_TTS=false         # Requires ElevenLabs extension
ENABLE_ADVANCED_TONE=false       # LLM-based tone classification

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_API=100               # Requests per minute (general API)
RATE_LIMIT_UPLOAD=10             # Uploads per minute
RATE_LIMIT_STREAMING=50          # Streaming requests per minute

# ── Document Limits ────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
MAX_PAGE_COUNT=500
DOCUMENT_TTL_DAYS=60
